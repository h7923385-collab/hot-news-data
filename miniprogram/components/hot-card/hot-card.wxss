.card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.card:active {
  transform: scale(0.98);
}

.rank-circle {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  color: #666;
  background: #f5f5f5;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-circle.top {
  background: #e94560;
  color: #fff;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.card-hot {
  font-size: 22rpx;
  color: #e94560;
  margin-right: 12rpx;
}

.card-source {
  font-size: 20rpx;
  color: #999;
}

.card-action {
  flex-shrink: 0;
  margin-left: 12rpx;
}
