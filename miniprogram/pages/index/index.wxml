<!-- 顶部分类导航 -->
<scroll-view class="category-bar" scroll-x enable-flex>
  <view 
    class="category-item {{currentCategory === 'tech' ? 'active' : ''}}"
    bindtap="switchCategory" data-category="tech">
    🚀 全球科技
  </view>
  <view 
    class="category-item {{currentCategory === 'dev' ? 'active' : ''}}"
    bindtap="switchCategory" data-category="dev">
    💻 开发者资讯
  </view>
  <view 
    class="category-item {{currentCategory === 'space' ? 'active' : ''}}"
    bindtap="switchCategory" data-category="space">
    🛰️ 航天探索
  </view>
  <view 
    class="category-item {{currentCategory === 'github' ? 'active' : ''}}"
    bindtap="switchCategory" data-category="github">
    ⭐ 开源趋势
  </view>
</scroll-view>

<!-- 刷新时间提示 -->
<view class="update-time" wx:if="{{updateTime}}">
  更新时间: {{updateTime}}
</view>

<!-- 加载状态 -->
<view class="loading" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text>正在获取最新热点...</text>
</view>

<!-- 错误提示 -->
<view class="error" wx:if="{{error}}">
  <text class="error-icon">⚠️</text>
  <text class="error-text">{{error}}</text>
  <button class="retry-btn" bindtap="loadHotNews">重新加载</button>
</view>

<!-- 热点列表 -->
<scroll-view 
  class="news-list" 
  scroll-y 
  wx:if="{{!loading && !error}}"
  bindscrolltolower="loadMore"
  refresher-enabled
  refresher-triggered="{{refreshing}}"
  bindrefresherrefresh="onRefresh">
  
  <view class="list-inner">
    <view class="list-header">
      <text class="list-title">{{categoryNames[currentCategory]}}</text>
      <text class="list-count">共 {{newsList.length}} 条</text>
    </view>

    <view 
      class="news-item" 
      wx:for="{{newsList}}" 
      wx:key="index"
      bindtap="goToDetail" 
      data-index="{{index}}"
      data-item="{{item}}">
      
      <!-- 排名 -->
      <view class="rank {{index < 3 ? 'top' : ''}}">
        {{index + 1}}
      </view>

      <!-- 内容 -->
      <view class="content">
        <view class="title">{{item.title}}</view>
        <view class="meta" wx:if="{{item.hot || item.desc}}">
          <text class="hot-tag" wx:if="{{item.hot}}">🔥 {{item.hot}}</text>
          <text class="desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        </view>
      </view>

      <!-- 收藏按钮 -->
      <view class="fav-btn" bindtap="toggleFavorite" data-item="{{item}}" catchtap>
        <text wx:if="{{isFavorited(item)}}">❤️</text>
        <text wx:else>🤍</text>
      </view>
    </view>
  </view>

  <!-- 底部加载更多 -->
  <view class="load-more" wx:if="{{loadingMore}}">
    <text>加载更多...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{newsList.length === 0 && !loading}}">
    <text class="empty-icon">📭</text>
    <text>暂无热点数据</text>
  </view>
</scroll-view>
