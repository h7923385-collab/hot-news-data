/* 分类导航栏 */
.category-bar {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 20rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.3s;
  flex-shrink: 0;
}

.category-item.active {
  background: #e94560;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.4);
}

/* 更新时间 */
.update-time {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 12rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 26rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top: 4rpx solid #e94560;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 错误提示 */
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.retry-btn {
  background: #e94560;
  color: #fff;
  border: none;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 热点列表 */
.news-list {
  height: calc(100vh - 180rpx);
}

.list-inner {
  padding: 16rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

/* 单条热点 */
.news-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
}

.news-item:active {
  transform: scale(0.98);
}

.rank {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #666;
  background: #f5f5f5;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank.top {
  background: #e94560;
  color: #fff;
}

.content {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.hot-tag {
  font-size: 22rpx;
  color: #e94560;
  margin-right: 12rpx;
}

.desc {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}

.fav-btn {
  padding: 8rpx 0 8rpx 16rpx;
  font-size: 36rpx;
  flex-shrink: 0;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
