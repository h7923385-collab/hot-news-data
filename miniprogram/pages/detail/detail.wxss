.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 顶部卡片 */
.hero-card {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 46, 0.25);
}

.tag-badge {
  display: inline-block;
  background: rgba(233, 69, 96, 0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 22rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}

.hero-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.source-label {
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.meta-divider {
  color: rgba(255, 255, 255, 0.3);
  margin: 0 16rpx;
}

.hot-label {
  color: #e94560;
  font-weight: 600;
}

/* 通用分区 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* 内容正文 */
.content-body {
  padding: 8rpx 0;
}

.content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  letter-spacing: 0.5rpx;
}

/* 分享按钮 */
/* 底部 */
.update-footer {
  text-align: center;
  padding: 20rpx;
  font-size: 22rpx;
  color: #ccc;
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

/* 分享按钮 */
.share-actions {
  display: flex;
  gap: 20rpx;
}

.share-btn, .copy-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.share-btn {
  background: #e94560;
  color: #fff;
}

.copy-btn {
  background: #f5f5f5;
  color: #333;
}

.share-btn:active, .copy-btn:active {
  opacity: 0.8;
}
