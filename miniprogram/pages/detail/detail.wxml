<view class="container">
  <!-- 顶部信息区 -->
  <view class="hero-card">
    <view class="tag-badge">{{tag}}</view>
    <text class="hero-title">{{title}}</text>
    <view class="hero-meta">
      <text class="source-label">{{sourceName}}</text>
      <text class="meta-divider">|</text>
      <text class="hot-label">🔥 {{hot}}</text>
    </view>
  </view>

  <!-- 详细内容 -->
  <view class="section">
    <view class="section-header">
      <text class="section-icon">📝</text>
      <text class="section-title">详细内容</text>
    </view>
    <view class="content-body">
      <text class="content-text">{{fullDesc}}</text>
    </view>
  </view>

  <!-- 复制分享 -->
  <view class="section">
    <view class="section-header">
      <text class="section-icon">🔗</text>
      <text class="section-title">分享</text>
    </view>
    <view class="share-actions">
      <button class="share-btn" open-type="share">📤 分享给好友</button>
      <button class="copy-btn" bindtap="copyContent">📋 复制内容</button>
    </view>
  </view>

  <!-- 更新时间 -->
  <view class="update-footer">
    <text>更新时间: {{time}}</text>
    <text>来源: {{source}}</text>
  </view>
</view>
